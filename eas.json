{
  "cli": {
    "version": ">= 15.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "ndk": "27.1.12297006",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
        "ORG_GRADLE_PROJECT_minSdkVersion": "24"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "ndk": "27.1.12297006",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
        "ORG_GRADLE_PROJECT_minSdkVersion": "24"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "ndk": "27.1.12297006"
      },
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
        "ORG_GRADLE_PROJECT_minSdkVersion": "24"
      }
    }
  },
